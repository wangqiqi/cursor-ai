---
description: ESLint integration SOP for JS/TS projects
globs:
  - "**/*.js"
  - "**/*.jsx"
  - "**/*.ts"
  - "**/*.tsx"
  - "**/.eslintrc*"
  - "**/eslint.config.*"
alwaysApply: false
